<Window x:Class="HelloWpfTriangle.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:local="clr-namespace:HelloWpfTriangle"
        Title="LightD3D12 WPF Triangle"
        Width="1180"
        Height="760"
        MinWidth="860"
        MinHeight="540"
        Background="#0F1318"
        Loaded="OnLoaded">
    <Grid>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="*" />
            <ColumnDefinition Width="300" />
        </Grid.ColumnDefinitions>

        <Border Grid.Column="0"
                Margin="18"
                BorderBrush="#2C3642"
                BorderThickness="1"
                Background="#090C10">
            <local:LightD3D12Host x:Name="RenderHost" />
        </Border>

        <Border Grid.Column="1"
                Background="#151B22"
                BorderBrush="#2C3642"
                BorderThickness="1,0,0,0">
            <StackPanel Margin="22">
                <TextBlock Text="LightD3D12"
                           Foreground="#F2F6FA"
                           FontSize="24"
                           FontWeight="SemiBold" />
                <TextBlock Text="WPF native render host"
                           Foreground="#9AA7B5"
                           Margin="0,4,0,24" />

                <TextBlock Text="Clear color"
                           Foreground="#F2F6FA"
                           FontWeight="SemiBold"
                           Margin="0,0,0,10" />

                <TextBlock Text="Red"
                           Foreground="#AAB6C3" />
                <Slider x:Name="RedSlider"
                        Minimum="0"
                        Maximum="1"
                        Value="0.04"
                        ValueChanged="OnClearColorChanged" />

                <TextBlock Text="Green"
                           Foreground="#AAB6C3"
                           Margin="0,10,0,0" />
                <Slider x:Name="GreenSlider"
                        Minimum="0"
                        Maximum="1"
                        Value="0.06"
                        ValueChanged="OnClearColorChanged" />

                <TextBlock Text="Blue"
                           Foreground="#AAB6C3"
                           Margin="0,10,0,0" />
                <Slider x:Name="BlueSlider"
                        Minimum="0"
                        Maximum="1"
                        Value="0.09"
                        ValueChanged="OnClearColorChanged" />

                <Separator Margin="0,22,0,22"
                           Background="#2C3642" />

                <TextBlock Text="Animation speed"
                           Foreground="#F2F6FA"
                           FontWeight="SemiBold"
                           Margin="0,0,0,10" />
                <Slider x:Name="SpeedSlider"
                        Minimum="0"
                        Maximum="4"
                        Value="1"
                        TickFrequency="0.5"
                        ValueChanged="OnSpeedChanged" />

                <Border Background="#10161D"
                        BorderBrush="#2C3642"
                        BorderThickness="1"
                        Padding="14"
                        Margin="0,26,0,0">
                    <StackPanel>
                        <TextBlock Text="Native DLL"
                                   Foreground="#F2F6FA"
                                   FontWeight="SemiBold" />
                        <TextBlock Text="LightD3D12WpfNative.dll"
                                   Foreground="#9AA7B5"
                                   Margin="0,4,0,0" />
                    </StackPanel>
                </Border>
            </StackPanel>
        </Border>
    </Grid>
</Window>
